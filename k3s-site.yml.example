# Site-specific variables for the k3s cluster.
# Copy this file to ~/k3s-site.yml and fill in your real values.
# Loaded automatically by ~/bin/k3s-ansible — never committed to git.

# Networking
master_ip: 10.0.0.50
lan_subnet: 10.0.0.0/24
dns_internal_ip: 10.0.0.21   # Authoritative DNS for internal domains (e.g. tinydns/djbdns)
dns_external_ip: 10.0.0.1    # Upstream DNS for external queries (e.g. router/pfSense)

# Domains
internal_domain: example.com
secondary_domain: example.org

# NFS
nfs_server: nfs.example.com
nfs_music_path: /data/media
nfs_k3s_path: /data/k3s
nfs_k3s_v4_path: /k3s          # NFSv4 path relative to V4 root on the NAS

# Lyrion NFS paths (NFSv4, relative to V4 root)
lyrion_nfs_config_path: /k3s/lyrion
lyrion_nfs_music_path: /media

# Service hostnames
rancher_hostname: rancher.example.com
lyrion_hostname: lyrion.example.com

# MetalLB VIPs
metallb_pool: "10.0.0.60-10.0.0.70"
lyrion_vip: 10.0.0.61
traefik_vip: 10.0.0.60

# Component versions (used during initial cluster provisioning)
k3s_version: "v1.35.5+k3s1"
helm_version: "v3.21.0"
cert_manager_version: "v1.20.2"
monitoring_retention: "3d"

# Additional Helm apps (deployed via k3s-ansible helm-apps.yml)
# site_helm_apps:
#   - name: harvester-ui-extension
#     chart: harvester-ui-ext/harvester
#     repo: harvester-ui-ext
#     repo_url: https://harvester.github.io/harvester-ui-extension/
#     namespace: cattle-ui-plugin-system
#     version: "1.8.0"
site_helm_apps: []
