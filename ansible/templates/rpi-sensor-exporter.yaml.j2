apiVersion: v1
kind: ConfigMap
metadata:
  name: rpi-sensor-exporter
  namespace: cattle-monitoring-system
data:
  exporter.py: |
    import http.server
    import socketserver

    PORT = 9101

    def read_temp_c():
      try:
        with open("/host-sys/class/thermal/thermal_zone0/temp", "r", encoding="utf-8") as f:
          return int(f.read().strip()) / 1000.0
      except Exception:
        return None

    def read_throttled_status():
      import subprocess, glob as _glob, os

      # Preferred: vcgencmd via the host binary (needs /dev/vcio mounted)
      vcgencmd = "/host-usr/bin/vcgencmd"
      if os.path.exists(vcgencmd):
        try:
          out = subprocess.check_output(
            [vcgencmd, "get_throttled"],
            env={"LD_LIBRARY_PATH": "/host-usr/lib"},
            timeout=2, stderr=subprocess.DEVNULL
          ).decode().strip()
          # output: "throttled=0x0"
          if "=" in out:
            return int(out.split("=", 1)[1], 16)
        except Exception:
          pass

      # Fallback: sysfs (older kernels / Pi 5)
      for path in [
        "/host-sys/devices/platform/soc/soc:firmware/get_throttled",
        "/host-sys/devices/platform/soc/firmware/get_throttled",
        *_glob.glob("/host-sys/devices/platform/soc/*/get_throttled"),
      ]:
        try:
          with open(path, "r", encoding="utf-8") as f:
            raw = f.read().strip()
            if "=" in raw:
              raw = raw.split("=", 1)[1]
            return int(raw, 16)
        except Exception:
          continue

      return None

    def metric_value(v):
      return "NaN" if v is None else str(v)

    def render_metrics():
      temp = read_temp_c()
      status = read_throttled_status()

      lines = [
        "# HELP rpi_cpu_temperature_celsius Raspberry Pi CPU temperature in Celsius",
        "# TYPE rpi_cpu_temperature_celsius gauge",
        f"rpi_cpu_temperature_celsius {metric_value(temp)}",
        "# HELP rpi_firmware_throttled_status Raspberry Pi firmware throttling bitmask from get_throttled",
        "# TYPE rpi_firmware_throttled_status gauge",
        f"rpi_firmware_throttled_status {metric_value(status)}",
        "# HELP rpi_firmware_throttled_current Current throttling flags (bits 0-3)",
        "# TYPE rpi_firmware_throttled_current gauge",
        f"rpi_firmware_throttled_current {metric_value((status & 0xF) if status is not None else None)}",
      ]
      return "\n".join(lines) + "\n"

    class Handler(http.server.BaseHTTPRequestHandler):
      def do_GET(self):
        if self.path != "/metrics":
          self.send_response(404)
          self.end_headers()
          return
        payload = render_metrics().encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; version=0.0.4")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

      def log_message(self, fmt, *args):
        return

    with socketserver.TCPServer(("", PORT), Handler) as httpd:
      httpd.serve_forever()
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: rpi-sensor-exporter
  namespace: cattle-monitoring-system
spec:
  selector:
    matchLabels:
      app: rpi-sensor-exporter
  template:
    metadata:
      labels:
        app: rpi-sensor-exporter
    spec:
      tolerations:
        - operator: Exists
      containers:
        - name: exporter
          image: python:3.12-slim
          command: ["python", "/app/exporter.py"]
          env:
            - name: PYTHONDONTWRITEBYTECODE
              value: "1"
          ports:
            - name: metrics
              containerPort: 9101
              protocol: TCP
          securityContext:
            runAsUser: 0
            readOnlyRootFilesystem: true
          volumeMounts:
            - name: exporter-script
              mountPath: /app/exporter.py
              subPath: exporter.py
              readOnly: true
            - name: host-sys
              mountPath: /host-sys
              readOnly: true
            - name: host-usr
              mountPath: /host-usr
              readOnly: true
            - name: vcio
              mountPath: /dev/vcio
      volumes:
        - name: exporter-script
          configMap:
            name: rpi-sensor-exporter
        - name: host-sys
          hostPath:
            path: /sys
            type: Directory
        - name: host-usr
          hostPath:
            path: /usr
            type: Directory
        - name: vcio
          hostPath:
            path: /dev/vcio
            type: CharDevice
---
apiVersion: v1
kind: Service
metadata:
  name: rpi-sensor-exporter
  namespace: cattle-monitoring-system
spec:
  selector:
    app: rpi-sensor-exporter
  ports:
    - name: metrics
      port: 9101
      targetPort: metrics
      protocol: TCP
---
apiVersion: monitoring.coreos.com/v1
kind: PodMonitor
metadata:
  name: rpi-sensor-exporter
  namespace: cattle-monitoring-system
  labels:
    release: rancher-monitoring
spec:
  namespaceSelector:
    matchNames:
      - cattle-monitoring-system
  selector:
    matchLabels:
      app: rpi-sensor-exporter
  podMetricsEndpoints:
    - port: metrics
      path: /metrics
      interval: 30s
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: rpi-sensor-dashboard
  namespace: cattle-dashboards
  labels:
    grafana_dashboard: "1"
data:
  rpi-sensor-dashboard.json: |
    {
      "uid": "rpi-sensor-dashboard",
      "title": "Raspberry Pi / Sensors",
      "schemaVersion": 39,
      "version": 2,
      "refresh": "30s",
      "tags": ["raspberry-pi", "sensors"],
      "templating": {
        "list": [
          {
            "name": "node",
            "type": "query",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "query": "label_values(rpi_cpu_temperature_celsius, pod)",
            "refresh": 2,
            "includeAll": true,
            "multi": true
          }
        ]
      },
      "panels": [
        {
          "id": 1,
          "type": "text",
          "title": "How to read throttling",
          "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
          "options": {
            "mode": "markdown",
            "content": "**Current flags (bits 0-3)**\\n- bit0: undervoltage now\\n- bit1: frequency capped now\\n- bit2: throttled now\\n- bit3: soft temperature limit now\\n\\n**Historical flags (bits 16-19)** show if those conditions happened since boot."
          }
        },
        {
          "id": 2,
          "type": "stat",
          "title": "Hottest node now",
          "gridPos": {"h": 4, "w": 6, "x": 0, "y": 4},
          "targets": [
            {
              "expr": "max(rpi_cpu_temperature_celsius{pod=~\"$node\"})",
              "legendFormat": "max"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "celsius",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 55},
                  {"color": "red", "value": 70}
                ]
              }
            },
            "overrides": []
          }
        },
        {
          "id": 3,
          "type": "stat",
          "title": "Nodes above 70C",
          "gridPos": {"h": 4, "w": 6, "x": 6, "y": 4},
          "targets": [
            {
              "expr": "sum(rpi_cpu_temperature_celsius{pod=~\"$node\"} > bool 70)",
              "legendFormat": "count"
            }
          ],
          "fieldConfig": {"defaults": {"min": 0, "decimals": 0}, "overrides": []}
        },
        {
          "id": 4,
          "type": "stat",
          "title": "Nodes throttling now (bit2)",
          "gridPos": {"h": 4, "w": 6, "x": 12, "y": 4},
          "targets": [
            {
              "expr": "sum((floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 4) % 2) == bool 1)",
              "legendFormat": "count"
            }
          ],
          "fieldConfig": {"defaults": {"min": 0, "decimals": 0}, "overrides": []}
        },
        {
          "id": 5,
          "type": "stat",
          "title": "Nodes ever throttled since boot (bit18)",
          "gridPos": {"h": 4, "w": 6, "x": 18, "y": 4},
          "targets": [
            {
              "expr": "sum((floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 262144) % 2) == bool 1)",
              "legendFormat": "count"
            }
          ],
          "fieldConfig": {"defaults": {"min": 0, "decimals": 0}, "overrides": []}
        },
        {
          "id": 6,
          "type": "timeseries",
          "title": "CPU Temperature by node",
          "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
          "targets": [
            {
              "expr": "rpi_cpu_temperature_celsius{pod=~\"$node\"}",
              "legendFormat": "{{ '{{pod}}' }}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "celsius",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 55},
                  {"color": "red", "value": 70}
                ]
              }
            },
            "overrides": []
          }
        },
        {
          "id": 7,
          "type": "timeseries",
          "title": "Current power/thermal conditions (0 or 1 per node)",
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
          "targets": [
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 1) % 2",
              "legendFormat": "undervoltage now {{ '{{pod}}' }}"
            },
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 2) % 2",
              "legendFormat": "freq capped now {{ '{{pod}}' }}"
            },
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 4) % 2",
              "legendFormat": "throttled now {{ '{{pod}}' }}"
            },
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 8) % 2",
              "legendFormat": "temp limit now {{ '{{pod}}' }}"
            }
          ],
          "fieldConfig": {"defaults": {"min": 0, "max": 1, "decimals": 0}, "overrides": []}
        },
        {
          "id": 8,
          "type": "timeseries",
          "title": "Historical conditions since boot (0 or 1 per node)",
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
          "targets": [
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 65536) % 2",
              "legendFormat": "undervoltage occurred {{ '{{pod}}' }}"
            },
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 131072) % 2",
              "legendFormat": "freq cap occurred {{ '{{pod}}' }}"
            },
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 262144) % 2",
              "legendFormat": "throttling occurred {{ '{{pod}}' }}"
            },
            {
              "expr": "floor(rpi_firmware_throttled_status{pod=~\"$node\"} / 524288) % 2",
              "legendFormat": "temp limit occurred {{ '{{pod}}' }}"
            }
          ],
          "fieldConfig": {"defaults": {"min": 0, "max": 1, "decimals": 0}, "overrides": []}
        }
      ]
    }
---
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: rpi-sensor-alerts
  namespace: cattle-monitoring-system
  labels:
    release: rancher-monitoring
spec:
  groups:
    - name: rpi-sensors
      interval: 60s
      rules:
        - alert: RpiTemperatureHigh
          expr: rpi_cpu_temperature_celsius > 75
          for: 2m
          labels:
            severity: warning
          annotations:
            summary: |-
              Raspberry Pi {{ '{{$labels.pod}}' }} temperature high
            description: |-
              Node {{ '{{$labels.pod}}' }} CPU temperature is {{ '{{$value | printf "%.1f"}}' }}°C (threshold 75°C).

        - alert: RpiTemperatureCritical
          expr: rpi_cpu_temperature_celsius > 80
          for: 1m
          labels:
            severity: critical
          annotations:
            summary: |-
              Raspberry Pi {{ '{{$labels.pod}}' }} temperature critical
            description: |-
              Node {{ '{{$labels.pod}}' }} CPU temperature is {{ '{{$value | printf "%.1f"}}' }}°C (threshold 80°C). Risk of thermal throttling or shutdown.

        # Active throttling (bits 0-3 of get_throttled)
        - alert: RpiThrottlingActive
          expr: rpi_firmware_throttled_current > 0
          for: 1m
          labels:
            severity: warning
          annotations:
            summary: |-
              Raspberry Pi {{ '{{$labels.pod}}' }} is actively throttled
            description: |-
              Node {{ '{{$labels.pod}}' }} firmware throttling flags are set (current bitmask 0x{{ '{{$value | printf "%x"}}' }}). Possible causes: undervoltage, overtemperature, or frequency capping.

        # Historical throttling since last boot (bits 16-19 of full status)
        - alert: RpiThrottledSinceBoot
          expr: (rpi_firmware_throttled_status / 65536) % 16 > 0
          for: 0m
          labels:
            severity: info
          annotations:
            summary: |-
              Raspberry Pi {{ '{{$labels.pod}}' }} has throttled since last boot
            description: |-
              Node {{ '{{$labels.pod}}' }} has experienced undervoltage, frequency capping, or thermal throttling since last boot (historical bits set in get_throttled).

        # Metric missing / exporter down
        - alert: RpiThrottledMetricMissing
          expr: absent(rpi_firmware_throttled_status) == 1
          for: 5m
          labels:
            severity: warning
          annotations:
            summary: "rpi_firmware_throttled_status metric is absent"
            description: "The rpi_firmware_throttled_status metric has not been scraped for 5 minutes. The sysfs get_throttled path may be missing on this kernel version, or the exporter pod is down."

        - alert: RpiTemperatureMetricMissing
          expr: absent(rpi_cpu_temperature_celsius) == 1
          for: 5m
          labels:
            severity: warning
          annotations:
            summary: "rpi_cpu_temperature_celsius metric is absent"
            description: "The rpi_cpu_temperature_celsius metric has not been scraped for 5 minutes. The rpi-sensor-exporter DaemonSet may be down."

        # NaN guard: metric present but value is NaN (exporter running but path unresolved)
        - alert: RpiThrottledMetricNaN
          expr: rpi_firmware_throttled_status != rpi_firmware_throttled_status
          for: 5m
          labels:
            severity: warning
          annotations:
            summary: |-
              rpi_firmware_throttled_status is NaN on {{ '{{$labels.pod}}' }}
            description: |-
              The get_throttled sysfs path could not be read on node {{ '{{$labels.pod}}' }}. The kernel may expose it at a different path. Check /sys/devices/platform/soc/*/get_throttled on the node.
