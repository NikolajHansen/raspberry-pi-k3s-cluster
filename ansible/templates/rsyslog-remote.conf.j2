# /etc/rsyslog.d/90-remote.conf — managed by Ansible, do not edit manually.
#
# Forwards node journal logs and Kubernetes pod logs to the central syslog
# receiver at {{ syslog_server }}:514 over TCP.
#
# See docs/logging.md for full architecture details.

# ── Inputs ────────────────────────────────────────────────────────────────────

# Read from the systemd journal (captures k3s, k3s-agent, containerd, kernel).
module(load="imjournal"
       StateFile="/var/lib/rsyslog/imjournal.state"
       IgnorePreviousMessages="off"
       Ratelimit.Burst="20000"
       Ratelimit.Interval="600")

# Tail Kubernetes pod log files from all namespaces.
# Path pattern: /var/log/pods/<ns>_<pod>_<uid>/<container>/<n>.log
# Pod identity is extracted and embedded as [namespace/podname] in the message.
module(load="imfile")
input(type="imfile"
      File="/var/log/pods/*/*/*log"
      Tag="k8s-pod"
      Facility="local6"
      Severity="info"
      addMetadata="on"
      freshStartTail="on"
      Ruleset="forward_k8s")

# ── Templates ─────────────────────────────────────────────────────────────────

# Pod log format: embeds [namespace/podname] at start of message body so
# syslog-ng on atlas can parse it for per-pod routing without hitting syslog
# TAG length limits.
template(name="PodLogFwd" type="string"
  string="<%pri%>%timereported% %HOSTNAME% k8s-pod: [%!ns%/%!pod%] %msg%\n")

# ── Rulesets ──────────────────────────────────────────────────────────────────

# Kubernetes pod logs: extract namespace and pod name from the file path,
# embed them in the message, then forward.
# File path: /var/log/pods/<namespace>_<podname>_<uuid>/<container>/<n>.log
ruleset(name="forward_k8s") {
    # Extract the 5th path component: <namespace>_<podname>_<uuid>
    set $!poddir = field($!metadata!filename, "/", 5);

    # Namespace is the text before the first underscore.
    set $!ns = field($!poddir, "_", 1);

    # Pod name is between the first underscore and the trailing _<UUID>.
    # UUID is 36 chars: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
    set $!pod = re_extract($!poddir,
        '^[^_]+_(.+)_[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$',
        0, 1, "unknown");

    action(type="omfwd"
           Target="{{ syslog_server }}"
           Port="514"
           Protocol="tcp"
           Template="PodLogFwd"
           queue.type="LinkedList"
           queue.size="10000"
           queue.saveOnShutdown="off"
           action.resumeRetryCount="-1"
           action.resumeInterval="30")
}

# ── Output: journal → TCP forwarding ─────────────────────────────────────────

# Use an action queue so messages are buffered in memory (not on disk) when the
# remote is temporarily unreachable. This preserves the stateless-node property.
action(type="omfwd"
       Target="{{ syslog_server }}"
       Port="514"
       Protocol="tcp"
       Template="RSYSLOG_ForwardFormat"
       queue.type="LinkedList"
       queue.size="10000"
       queue.saveOnShutdown="off"
       action.resumeRetryCount="-1"
       action.resumeInterval="30"
       filter.f_expression="prifilt('*.warn') or
         ($syslogseverity <= 5) or
         ($programname == 'k3s') or
         ($programname == 'k3s-agent') or
         ($programname == 'containerd') or
         ($syslogfacility-text == 'kern') or
         ($syslogfacility-text == 'auth') or
         ($syslogfacility-text == 'authpriv')")
