apiVersion: v1
kind: ConfigMap
metadata:
  name: coredns-custom
  namespace: kube-system
data:
  # Forward internal domains to authoritative DNS (djbdns/tinydns).
  # NOTE: Do NOT add a .:53 server block here — CoreDNS already defines one in
  # its main Corefile. A duplicate .:53 will crash CoreDNS on startup.
  # External DNS forwarding is patched directly into the main Corefile.
  internal.server: |
    {{ internal_domain }}:53 {{ secondary_domain }}:53 {{ lan_subnet | regex_replace('\\.0/.*', '') }}.in-addr.arpa:53 {
        errors
        cache 30
        forward . {{ dns_internal_ip }}
    }
