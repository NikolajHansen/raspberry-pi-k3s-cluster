# Copy this file to credentials.yml, fill in values, then encrypt:
#   ansible-vault encrypt credentials.yml
#
# To run playbooks with vault:
#   ansible-playbook --ask-vault-pass ...
#   or store password in .vault_pass (gitignored) and use:
#   ansible-playbook --vault-password-file .vault_pass ...

ansible_password: ""
